<Window x:Class="IMOS.PriceUpdater.Views.PriceUpdateView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:IMOS.PriceUpdater.Views"
        xmlns:vm="clr-namespace:IMOS.PriceUpdater.ViewModels"
        Title="Price Update Execution"
        Width="700"
        Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

        <!-- Style for section headers -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,10,0,5" />
        </Style>

        <!-- Style for labels -->
        <Style x:Key="LabelStyle" TargetType="Label">
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>

        <!-- Style for file path text boxes -->
        <Style x:Key="FilePathStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="5" />
            <Setter Property="Margin" Value="0,2,5,5" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="Background" Value="#F5F5F5" />
        </Style>

        <!-- Style for error messages -->
        <Style x:Key="ErrorMessageStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Red" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>

        <!-- Style for success messages -->
        <Style x:Key="SuccessMessageStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Green" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>

        <!-- Style for stat labels -->
        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>

        <!-- Style for stat values -->
        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- File Selection Section -->
        <TextBlock Grid.Row="0" 
                   Text="File Selection" 
                   Style="{StaticResource SectionHeaderStyle}" />

        <!-- CSV File Selection -->
        <Grid Grid.Row="1" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Style="{StaticResource FilePathStyle}"
                     Text="{Binding CsvFilePath}" />
            <Button Grid.Column="1"
                    Content="Select CSV File"
                    Width="120"
                    Command="{Binding SelectCsvFileCommand}"
                    IsEnabled="{Binding IsNotExecuting}" />
        </Grid>

        <!-- Configuration File Selection -->
        <Grid Grid.Row="2" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Style="{StaticResource FilePathStyle}"
                     Text="{Binding ConfigFilePath}" />
            <Button Grid.Column="1"
                    Content="Load Config"
                    Width="100"
                    Margin="0,0,5,0"
                    Command="{Binding LoadConfigurationCommand}"
                    IsEnabled="{Binding CanLoadConfiguration}" />
            <Button Grid.Column="2"
                    Content="Clear"
                    Width="60"
                    Command="{Binding ClearCommand}"
                    IsEnabled="{Binding IsNotExecuting}" />
        </Grid>

        <!-- Progress Section -->
        <TextBlock Grid.Row="3" 
                   Text="Progress" 
                   Style="{StaticResource SectionHeaderStyle}"
                   Margin="0,15,0,5" />

        <!-- Progress Bar -->
        <Grid Grid.Row="4" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0"
                         Height="25"
                         Value="{Binding ProgressPercentage}"
                         Maximum="100"
                         Margin="0,0,10,0" />
            <TextBlock Grid.Column="1"
                       Width="60"
                       TextAlignment="Right"
                       VerticalAlignment="Center">
                <Run Text="{Binding ProgressPercentage, StringFormat={}{0:F0}}" /><Run Text="%"/>
            </TextBlock>
        </Grid>

        <!-- Status Message -->
        <TextBlock Grid.Row="5" 
                   Text="{Binding StatusMessage}"
                   Margin="0,5,0,0"
                   TextWrapping="Wrap" />

        <!-- Results Summary -->
        <Border Grid.Row="6" 
                Margin="0,10,0,0"
                Padding="10"
                BorderBrush="Gray"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Summary Stats -->
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <StackPanel Margin="0,0,30,0">
                        <TextBlock Text="Total Rows" Style="{StaticResource StatLabelStyle}" />
                        <TextBlock Text="{Binding TotalRows}" Style="{StaticResource StatValueStyle}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,30,0">
                        <TextBlock Text="Processed" Style="{StaticResource StatLabelStyle}" />
                        <TextBlock Text="{Binding ProcessedRows}" Style="{StaticResource StatValueStyle}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,30,0">
                        <TextBlock Text="Updated" Style="{StaticResource StatLabelStyle}" />
                        <TextBlock Text="{Binding UpdatedCount}" 
                                   Style="{StaticResource StatValueStyle}" 
                                   Foreground="Green" />
                    </StackPanel>
                    <StackPanel Margin="0,0,30,0">
                        <TextBlock Text="Skipped" Style="{StaticResource StatLabelStyle}" />
                        <TextBlock Text="{Binding SkippedCount}" 
                                   Style="{StaticResource StatValueStyle}" 
                                   Foreground="Orange" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Errors" Style="{StaticResource StatLabelStyle}" />
                        <TextBlock Text="{Binding ErrorCount}" 
                                   Style="{StaticResource StatValueStyle}" 
                                   Foreground="Red" />
                    </StackPanel>
                </StackPanel>

                <!-- Error Details (shown when there are errors) -->
                <TextBlock Grid.Row="1" 
                           Text="{Binding ErrorMessage}" 
                           Style="{StaticResource ErrorMessageStyle}"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisConverter}}"
                           Margin="0,10,0,0" />
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="7" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="Cancel"
                    Width="100"
                    Margin="0,0,10,0"
                    Command="{Binding CancelCommand}"
                    IsEnabled="{Binding IsExecuting}" />
            <Button Content="Execute Update"
                    Width="130"
                    Command="{Binding ExecuteCommand}"
                    IsEnabled="{Binding IsNotExecuting}" />
        </StackPanel>

        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="8"
                Background="#80FFFFFF"
                Visibility="{Binding IsExecuting, Converter={StaticResource BoolToVisConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="200"
                             Height="4" />
                <TextBlock Text="Processing..."
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>

