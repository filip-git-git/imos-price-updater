<Window x:Class="IMOS.PriceUpdater.Views.ColumnMappingView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:IMOS.PriceUpdater.Views"
        Title="CSV Column Mapping"
        Width="700"
        Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        
        <!-- Style for section headers -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,10,0,5" />
        </Style>
        
        <!-- Style for labels -->
        <Style x:Key="LabelStyle" TargetType="Label">
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>
        
        <!-- Style for text boxes -->
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="5" />
            <Setter Property="Margin" Value="0,2,0,5" />
        </Style>
        
        <!-- Style for error messages -->
        <Style x:Key="ErrorMessageStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Red" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>
        
        <!-- Style for success messages -->
        <Style x:Key="SuccessMessageStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Green" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>
        
        <!-- DataGrid style for preview -->
        <Style x:Key="PreviewDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="True" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="All" />
            <Setter Property="BorderBrush" Value="Gray" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,5,0,5" />
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <!-- CSV File Selection -->
        <TextBlock Grid.Row="0" 
                   Grid.ColumnSpan="2"
                   Text="CSV File" 
                   Style="{StaticResource SectionHeaderStyle}" />
        
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,25,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" 
                     Style="{StaticResource TextBoxStyle}"
                     Text="{Binding CsvFilePath, Mode=OneWay}"
                     IsReadOnly="True" />
            <Button Grid.Column="1" 
                    Content="Browse..."
                    Width="80"
                    Margin="10,0,0,0"
                    Command="{Binding SelectCsvFileCommand}" />
        </Grid>
        
        <!-- CSV Headers -->
        <TextBlock Grid.Row="1" 
                   Grid.Column="0"
                   Text="CSV Columns"
                   Style="{StaticResource SectionHeaderStyle}" />
        
        <ListBox Grid.Row="1" Grid.Column="0"
                 Margin="0,25,10,5"
                 Height="120"
                 ItemsSource="{Binding CsvHeaders}"
                 BorderBrush="Gray"
                 BorderThickness="1" />
        
        <!-- Table Selection -->
        <TextBlock Grid.Row="1" 
                   Grid.Column="1"
                   Text="Database Table"
                   Style="{StaticResource SectionHeaderStyle}" />
        
        <ComboBox Grid.Row="1" Grid.Column="1"
                  Margin="0,25,0,5"
                  Height="25"
                  ItemsSource="{Binding AvailableTables}"
                  DisplayMemberPath="FullyQualifiedName"
                  SelectedValuePath="FullyQualifiedName"
                  SelectedValue="{Binding SelectedTable}"
                  IsEnabled="{Binding IsLoadingTables, Converter={StaticResource BoolToVisConverter}}" />
        
        <!-- Column Mapping -->
        <TextBlock Grid.Row="2" 
                   Grid.Column="0"
                   Text="Search Column Mapping"
                   Style="{StaticResource SectionHeaderStyle}" />
        
        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,25,10,5">
            <Label Content="CSV Search Column:" />
            <ComboBox ItemsSource="{Binding CsvHeaders}"
                      SelectedItem="{Binding SelectedSearchColumn}"
                      Margin="0,2,0,5" />
            
            <Label Content="SQL Search Column:" />
            <ComboBox ItemsSource="{Binding AvailableColumns}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Name"
                      SelectedValue="{Binding SelectedSearchColumn}"
                      Margin="0,2,0,5" />
        </StackPanel>
        
        <TextBlock Grid.Row="2" 
                   Grid.Column="1"
                   Text="Price Column Mapping"
                   Style="{StaticResource SectionHeaderStyle}" />
        
        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,25,0,5">
            <Label Content="CSV Price Column:" />
            <ComboBox ItemsSource="{Binding CsvHeaders}"
                      SelectedItem="{Binding SelectedPriceColumn}"
                      Margin="0,2,0,5" />
            
            <Label Content="SQL Price Column:" />
            <ComboBox ItemsSource="{Binding AvailableColumns}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Name"
                      SelectedValue="{Binding SelectedPriceColumn}"
                      Margin="0,2,0,5" />
        </StackPanel>
        
        <!-- CSV Preview -->
        <TextBlock Grid.Row="3" 
                   Grid.ColumnSpan="2"
                   Text="CSV Preview (First 5 Rows)"
                   Style="{StaticResource SectionHeaderStyle}" />
        
        <DataGrid Grid.Row="4" Grid.ColumnSpan="2"
                  x:Name="PreviewDataGrid"
                  Style="{StaticResource PreviewDataGridStyle}"
                  ItemsSource="{Binding PreviewRows}" />
        
        <!-- Validation Message -->
        <Border Grid.Row="5" Grid.ColumnSpan="2" 
                Margin="0,10,0,0"
                Padding="10"
                BorderBrush="Gray"
                BorderThickness="1">
            <TextBlock Text="{Binding ValidationMessage}" 
                       TextWrapping="Wrap" />
        </Border>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Clear"
                    Width="80"
                    Margin="0,0,10,0"
                    Command="{Binding ClearMappingCommand}" />
            <Button Content="Validate"
                    Width="80"
                    Margin="0,0,10,0"
                    Command="{Binding ValidateMappingCommand}"
                    IsEnabled="{Binding CanValidateMapping}" />
            <Button Content="OK"
                    Width="80"
                    Click="OkButton_Click"
                    IsEnabled="{Binding IsValidMapping}" />
        </StackPanel>
        
        <!-- Loading Indicator -->
        <ProgressBar Grid.Row="4" Grid.ColumnSpan="2" 
                     IsIndeterminate="True"
                     Height="4"
                     VerticalAlignment="Top"
                     Visibility="{Binding IsLoadingTables, Converter={StaticResource BoolToVisConverter}}" />
    </Grid>
</Window>

