<Window x:Class="IMOS.PriceUpdater.Views.ConnectionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:IMOS.PriceUpdater.Views"
        xmlns:models="clr-namespace:IMOS.PriceUpdater.Models"
        Title="Database Connection"
        Width="500"
        Height="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
        
        <!-- Style for section headers -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,10,0,5" />
        </Style>
        
        <!-- Style for labels -->
        <Style x:Key="LabelStyle" TargetType="Label">
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>
        
        <!-- Style for text boxes -->
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="5" />
            <Setter Property="Margin" Value="0,2,0,5" />
        </Style>
        
        <!-- Style for error messages -->
        <Style x:Key="ErrorMessageStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Red" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>
        
        <!-- Style for success messages -->
        <Style x:Key="SuccessMessageStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Green" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <!-- Server Name -->
        <TextBlock Grid.Row="0" 
                   Text="Server Name" 
                   Style="{StaticResource SectionHeaderStyle}" />
        <TextBox Grid.Row="0" 
                 x:Name="ServerNameTextBox"
                 Style="{StaticResource TextBoxStyle}"
                 Margin="0,25,0,5"
                 Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}" />
        
        <!-- Authentication Mode -->
        <TextBlock Grid.Row="1" 
                   Text="Authentication" 
                   Style="{StaticResource SectionHeaderStyle}" />
        <StackPanel Grid.Row="1" Margin="0,25,0,5" Orientation="Horizontal">
            <RadioButton Content="SQL Authentication" 
                         IsChecked="{Binding IsSqlAuthentication}"
                         Margin="0,0,20,0" />
            <RadioButton Content="Windows Authentication" 
                         IsChecked="{Binding IsWindowsAuthentication}" />
        </StackPanel>
        
        <!-- Username and Password (visible when SQL Auth is selected) -->
        <StackPanel Grid.Row="2" 
                    Visibility="{Binding IsSqlAuthentication, Converter={StaticResource BoolToVisConverter}}">
            <Label Content="Username" Style="{StaticResource LabelStyle}" />
            <TextBox Style="{StaticResource TextBoxStyle}"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
            
            <Label Content="Password" Style="{StaticResource LabelStyle}" />
            <PasswordBox x:Name="PasswordBox"
                        Margin="0,2,0,5"
                        PasswordChanged="PasswordBox_PasswordChanged" />
        </StackPanel>
        
        <!-- Connection Timeout -->
        <TextBlock Grid.Row="3" 
                   Text="Connection Settings" 
                   Style="{StaticResource SectionHeaderStyle}" />
        <StackPanel Grid.Row="3" Margin="0,25,0,5" Orientation="Horizontal">
            <Label Content="Timeout (seconds):" VerticalAlignment="Center" />
            <TextBox Width="60" 
                     Margin="10,0,0,0"
                     Text="{Binding ConnectionTimeout, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>
        
        <!-- Database Selection -->
        <TextBlock Grid.Row="4" 
                   Text="Database" 
                   Style="{StaticResource SectionHeaderStyle}" />
        <ComboBox Grid.Row="4" 
                  x:Name="DatabaseComboBox"
                  Margin="0,25,0,5"
                  IsEditable="True"
                  Text="{Binding SelectedDatabase, UpdateSourceTrigger=PropertyChanged}"
                  ItemsSource="{Binding AvailableDatabases}" />
        
        <!-- Connection Status -->
        <Border Grid.Row="5" 
                Margin="0,10,0,0"
                Padding="10"
                Background="{Binding IsConnected, Converter={StaticResource BoolToVisConverter}, ConverterParameter=LightGreen}"
                BorderBrush="Gray"
                BorderThickness="1">
            <TextBlock Text="{Binding ConnectionStatus}" 
                       TextWrapping="Wrap" />
        </Border>
        
        <!-- Error Message -->
        <TextBlock Grid.Row="6" 
                   Text="{Binding ErrorMessage}" 
                   Style="{StaticResource ErrorMessageStyle}"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisConverter}}" />
        
        <!-- Buttons -->
        <StackPanel Grid.Row="8" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Cancel"
                    Width="80"
                    Margin="0,0,10,0"
                    Command="{Binding CancelCommand}"
                    IsEnabled="{Binding IsTesting}" />
            <Button Content="Test Connection"
                    Width="120"
                    Margin="0,0,10,0"
                    Command="{Binding TestConnectionCommand}"
                    IsEnabled="{Binding CanTestConnection}" />
            <Button Content="Connect"
                    Width="80"
                    Click="ConnectButton_Click"
                    IsEnabled="{Binding IsConnected}" />
        </StackPanel>
        
        <!-- Loading Indicator -->
        <ProgressBar Grid.Row="7" 
                     IsIndeterminate="True"
                     Height="4"
                     Margin="0,10,0,0"
                     Visibility="{Binding IsTesting, Converter={StaticResource BoolToVisConverter}}" />
    </Grid>
</Window>

