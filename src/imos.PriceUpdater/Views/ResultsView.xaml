<UserControl x:Class="IMOS.PriceUpdater.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Status Color Converters -->
        <Style x:Key="UpdatedRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Updated">
                    <Setter Property="Background" Value="#E8F5E9"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Skipped">
                    <Setter Property="Background" Value="#FFF8E1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Error">
                    <Setter Property="Background" Value="#FFEBEE"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
            <TextBlock Text="Execution Results" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock Text=" - " VerticalAlignment="Center" Margin="5,0"/>
            <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} total'}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Filter Bar -->
        <Grid Grid.Row="1" Margin="5,0,5,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Search:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     VerticalAlignment="Center" Padding="3"/>

            <TextBlock Grid.Column="2" Text="Status:" VerticalAlignment="Center" Margin="15,0,5,0"/>
            <ComboBox Grid.Column="3" SelectedValue="{Binding StatusFilter}" VerticalAlignment="Center">
                <ComboBoxItem Content="All" IsSelected="True"/>
                <ComboBoxItem Content="Updated"/>
                <ComboBoxItem Content="Skipped"/>
                <ComboBoxItem Content="Errors"/>
            </ComboBox>

            <Button Grid.Column="5" Content="Export to CSV" Command="{Binding ExportToCsvCommand}" 
                    Padding="10,3" Margin="5,0"/>
        </Grid>

        <!-- Results DataGrid -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding ResultsView}" 
                  SelectedItem="{Binding SelectedResult}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  RowStyle="{StaticResource UpdatedRowStyle}"
                  CanUserSortColumns="True"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  Margin="5,0">
            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenDetailCommand}"/>
            </DataGrid.InputBindings>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy" Command="{Binding CopyCellCommand}" 
                              CommandParameter="{Binding SelectedResult.MaterialId}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Material ID" Binding="{Binding MaterialId}" Width="120"/>
                <DataGridTextColumn Header="Search Term" Binding="{Binding SearchTerm}" Width="200"/>
                <DataGridTextColumn Header="Old Price" Binding="{Binding OldPrice, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="New Price" Binding="{Binding NewPrice, StringFormat=N2}" Width="100"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                <DataGridTextColumn Header="Error Details" Binding="{Binding ErrorMessage}" Width="*"/>
                <DataGridTextColumn Header="Row #" Binding="{Binding SourceRowNumber}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Updated: "/>
                    <TextBlock Text="{Binding UpdatedCount}" Foreground="Green" FontWeight="Bold"/>
                    <TextBlock Text=" | Skipped: "/>
                    <TextBlock Text="{Binding SkippedCount}" Foreground="Orange" FontWeight="Bold"/>
                    <TextBlock Text=" | Errors: "/>
                    <TextBlock Text="{Binding ErrorCount}" Foreground="Red" FontWeight="Bold"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Detail Dialog Overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="4" 
              Visibility="{Binding IsDetailDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
              Background="#80000000">
            <Border Background="White" 
                    BorderBrush="Gray" 
                    BorderThickness="1" 
                    CornerRadius="5"
                    Padding="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="500">
                <StackPanel>
                    <TextBlock Text="Error Details" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="{Binding SelectedResult.MaterialId}" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SelectedResult.SearchTerm}" Margin="0,5,0,15"/>

                    <TextBlock Text="Error Message:" FontWeight="Bold"/>
                    <TextBox Text="{Binding DetailErrorMessage, Mode=OneWay}" 
                             IsReadOnly="True" 
                             TextWrapping="Wrap"
                             Height="100"
                             Margin="0,5,0,15"/>

                    <Button Content="Close" 
                            Command="{Binding CloseDetailCommand}" 
                            HorizontalAlignment="Right"
                            Padding="20,5"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
