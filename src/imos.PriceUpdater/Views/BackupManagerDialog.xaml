<Window x:Class="IMOS.PriceUpdater.Views.BackupManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Backup Manager" 
        Height="500" 
        Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Backup Manager" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}" 
                    Margin="20,0,0,0" Padding="10,3"/>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Create Backup" Command="{Binding CreateBackupCommand}" 
                    Padding="15,5" Margin="0,0,5,0"/>
            <Button Content="Restore" Command="{Binding RestoreCommand}" 
                    Padding="15,5" Margin="0,0,5,0"/>
            <Button Content="Delete" Command="{Binding DeleteCommand}" 
                    Padding="15,5"/>
        </StackPanel>

        <!-- Backups List -->
        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding Backups}" 
                  SelectedItem="{Binding SelectedBackup}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*"/>
                <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat='yyyy-MM-dd HH:mm'}" Width="130"/>
                <DataGridTextColumn Header="Size" Binding="{Binding FormattedSize}" Width="80"/>
                <DataGridTextColumn Header="Source Config" Binding="{Binding SourceConfigFileName}" Width="150"/>
                <DataGridCheckBoxColumn Header="Auto" Binding="{Binding IsAutoBackup}" Width="50"/>
                <DataGridCheckBoxColumn Header="Compressed" Binding="{Binding IsCompressed}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Settings -->
        <GroupBox Grid.Row="3" Header="Settings" Margin="0,10,0,0" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Retention Count:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Grid.Column="1" Text="{Binding RetentionCount}" VerticalAlignment="Center" Padding="3"/>

                <TextBlock Grid.Column="2" Text="Backup Directory:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <TextBox Grid.Column="3" Text="{Binding BackupDirectory}" VerticalAlignment="Center" Padding="3" Margin="0,0,5,0"/>

                <Button Grid.Column="4" Content="Save Settings" Command="{Binding SaveSettingsCommand}" 
                        Padding="10,3"/>
            </Grid>
        </GroupBox>

        <!-- Status Bar -->
        <StatusBar Grid.Row="4" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Loading Overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="5" 
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
              Background="#80000000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Loading..." FontSize="16" Foreground="White"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
