<Window x:Class="IMOS.PriceUpdater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IMOS.PriceUpdater"
        xmlns:vm="clr-namespace:IMOS.PriceUpdater.ViewModels"
        mc:Ignorable="d"
        Title="imos Price Updater" 
        Height="600" 
        Width="900"
        MinHeight="500"
        MinWidth="700"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="About_Click" />
            </MenuItem>
        </Menu>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="imos Price Updater" 
                       FontSize="24" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20" />

            <GroupBox Grid.Row="1" Header="CSV File" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" 
                             Text="{Binding CsvFilePath, Mode=OneWay}" 
                             IsReadOnly="True"
                             VerticalAlignment="Center"
                             Margin="5" />
                    <Button Grid.Column="1" 
                            Content="Browse..." 
                            Command="{Binding SelectCsvFileCommand}"
                            Margin="5" />
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="2" Header="Configuration File" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" 
                             Text="{Binding ConfigFilePath, Mode=OneWay}" 
                             IsReadOnly="True"
                             VerticalAlignment="Center"
                             Margin="5" />
                    <Button Grid.Column="1" 
                            Content="Browse..." 
                            Command="{Binding SelectConfigFileCommand}"
                            Margin="5" />
                    <Button Grid.Column="2"
                            Content="Test Connection"
                            Click="TestConnection_Click"
                            Margin="5"
                            MinWidth="100" />
                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="3" Header="Connection Status" Margin="0,0,0,10">
                <TextBlock x:Name="ConnectionStatusText" 
                           Text="Not connected"
                           Margin="5"
                           Foreground="Gray" />
            </GroupBox>

            <StackPanel Grid.Row="4" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center"
                        Margin="0,10">
                <Button Content="Execute Update" 
                        Command="{Binding ExecuteCommand}"
                        IsEnabled="{Binding IsNotExecuting}"
                        Padding="16,8"
                        MinWidth="100"
                        Margin="5" />
            </StackPanel>

            <GroupBox Grid.Row="5" Header="Progress" Margin="0,0,0,10">
                <StackPanel Margin="5">
                    <ProgressBar Value="{Binding ProgressValue}" 
                                 Height="20" 
                                 Margin="0,0,0,5" />
                    <TextBlock Text="{Binding StatusMessage}" 
                               HorizontalAlignment="Center"
                               FontStyle="Italic" />
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="6" Header="Results" Margin="0,0,0,10">
                <StackPanel>
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Ellipse Width="14" Height="14" Fill="#28A745" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="Updated: " FontWeight="Bold" Foreground="#28A745" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding UpdatedCount}" Foreground="#28A745" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Ellipse Width="14" Height="14" Fill="#FFC107" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="Skipped: " FontWeight="Bold" Foreground="#FFC107" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SkippedCount}" Foreground="#FFC107" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Ellipse Width="14" Height="14" Fill="#DC3545" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="Errors: " FontWeight="Bold" Foreground="#DC3545" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ErrorCount}" Foreground="#DC3545" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                        <TextBlock Text="Total rows: " Foreground="Gray" />
                        <TextBlock Text="{Binding TotalRows}" FontWeight="Bold" />
                        <TextBlock Text=" | Duration: " Foreground="Gray" Margin="20,0,0,0" />
                        <TextBlock Text="{Binding DurationSeconds, StringFormat={}{0:F2}s}" FontWeight="Bold" />
                        <TextBlock Text=" | Success Rate: " Foreground="Gray" Margin="20,0,0,0" />
                        <TextBlock Text="{Binding SuccessRate, StringFormat={}{0:F1}%}" FontWeight="Bold" />
                    </StackPanel>

                    <Separator Margin="0,10" />

                    <TextBox Text="{Binding ResultSummary, Mode=OneWay}" 
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             BorderThickness="0"
                             VerticalScrollBarVisibility="Auto"
                             Margin="5" />
                </StackPanel>
            </GroupBox>

            <StatusBar Grid.Row="7">
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusMessage}" />
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </DockPanel>
</Window>
