<Window x:Class="IMOS.PriceUpdater.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About imos Price Updater"
        Height="350"
        Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="imos Price Updater"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10" />

        <TextBlock Grid.Row="1"
                   Text="Version 1.0"
                   FontSize="14"
                   Foreground="Gray"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10" />

        <TextBlock Grid.Row="2"
                   Text="Bulk update prices from CSV to IMOS CAD database."
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Margin="0,0,0,20" />

        <TextBlock Grid.Row="3"
                   Text="Author:"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,5" />

        <TextBlock Grid.Row="4"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15">
            <Hyperlink NavigateUri="https://github.com/filip-git-git"
                       RequestNavigate="Hyperlink_RequestNavigate"
                       FontSize="14"
                       FontWeight="Bold">
                https://github.com/filip-git-git
            </Hyperlink>
        </TextBlock>

        <Border Grid.Row="5"
                BorderBrush="LightGray"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10"
                Background="#F5F5F5">
            <StackPanel>
                <TextBlock Text="License: Apache License 2.0"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5" />
                <TextBlock Text="This application is provided as-is, without warranty of any kind."
                           FontSize="10"
                           Foreground="Gray"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
            </StackPanel>
        </Border>

        <Button Grid.Row="6"
                Content="OK"
                Click="OK_Click"
                HorizontalAlignment="Center"
                Padding="30,5"
                Margin="0,15,0,0" />
    </Grid>
</Window>
